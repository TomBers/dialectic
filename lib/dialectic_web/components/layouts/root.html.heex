<!DOCTYPE html>
<html lang="en" class="[scrollbar-gutter:stable]">
  <head>
    <% canonical_url =
      assigns[:canonical_url] || DialecticWeb.Endpoint.url() <> (@conn.request_path || "") %>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta
      name="description"
      content={
        assigns[:page_description] ||
          "Turn messy linear chat into visual grids. Explore complex topics, reason together, and build a living knowledge base with RationalGrid."
      }
    />
    <%= if assigns[:noindex] do %>
      <meta name="robots" content="noindex, nofollow" />
    <% end %>
    <link rel="canonical" href={canonical_url} />
    <meta property="og:url" content={canonical_url} />
    <meta property="og:site_name" content="RationalGrid" />
    <meta property="og:type" content={assigns[:og_type] || "website"} />
    <meta
      property="og:title"
      content={assigns[:page_title] || "RationalGrid - Collaborative AI-Augmented Learning"}
    />
    <meta
      property="og:description"
      content={
        assigns[:page_description] ||
          "Turn messy linear chat into visual grids. Explore complex topics, reason together, and build a living knowledge base with RationalGrid."
      }
    />
    <%= if assigns[:og_image] do %>
      <meta property="og:image" content={@og_image} />
      <meta name="twitter:image" content={@og_image} />
    <% end %>
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical_url} />
    <meta
      name="twitter:title"
      content={assigns[:page_title] || "RationalGrid - Collaborative AI-Augmented Learning"}
    />
    <meta
      name="twitter:description"
      content={
        assigns[:page_description] ||
          "Turn messy linear chat into visual grids. Explore complex topics, reason together, and build a living knowledge base with RationalGrid."
      }
    />

    <%= if assigns[:json_ld] do %>
      <script type="application/ld+json">
        <%= raw(@json_ld) %>
      </script>
    <% end %>

    <.live_title default="RationalGrid" suffix=" : Explore Ideas Together">
      {assigns[:page_title]}
    </.live_title>
    <link rel="icon" type="image/webp" href={~p"/images/favicon.webp"} />
    <link rel="icon" type="image/png" href={~p"/images/favicon.png"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-NZDE9PL5FG">
    </script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-NZDE9PL5FG');
    </script>
  </head>
  <body class="bg-white">
    <% active_path = @conn.request_path %>
    <header
      class="sticky top-0 z-[9999] h-9 border-b border-[#2d0a84]/70 bg-gradient-to-r from-[#2d0a84] via-[#4736cf] to-[#4c6fff]"
      id="userHeader"
    >
      <nav class="mx-auto flex h-full w-full max-w-7xl items-center justify-between gap-3 px-3 text-xs">
        <div class="flex items-center gap-4">
          <.link
            href={~p"/"}
            class="inline-flex items-center gap-2 rounded-full bg-black/10 px-2 py-1 text-white transition hover:bg-white/24 hover:text-white hover:ring-2 hover:ring-white/45 hover:shadow-[0_8px_18px_rgba(24,16,88,0.26)]"
          >
            <img src={~p"/images/favicon.webp"} alt="RationalGrid" class="h-5 w-5" />
            <span class="hidden font-bold tracking-tight sm:inline">RationalGrid</span>
          </.link>
        </div>
        <div class="flex items-center gap-1 rounded-full bg-white/12 px-1 py-0.5 text-white ring-1 ring-white/20 shadow-inner shadow-white/5 sm:gap-1.5">
          <.link
            href={~p"/intro/how"}
            class={[
              "inline-flex items-center gap-1 rounded-full px-2 py-1 font-semibold text-white transition",
              if(active_path == "/intro/how",
                do: "bg-white/24 text-white shadow-sm",
                else:
                  "hover:bg-white/22 hover:text-white hover:ring-1 hover:ring-white/35 hover:shadow-[0_6px_14px_rgba(24,16,88,0.24)]"
              )
            ]}
          >
            <.icon name="hero-book-open" class="h-3.5 w-3.5" />
            <span class="hidden sm:inline">Guide</span>
          </.link>
          <.link
            href={~p"/about"}
            class={[
              "inline-flex items-center gap-1 rounded-full px-2 py-1 font-semibold text-white transition",
              if(active_path == "/about",
                do: "bg-white/24 text-white shadow-sm",
                else:
                  "hover:bg-white/22 hover:text-white hover:ring-1 hover:ring-white/35 hover:shadow-[0_6px_14px_rgba(24,16,88,0.24)]"
              )
            ]}
          >
            <.icon name="hero-information-circle" class="h-3.5 w-3.5" />
            <span class="hidden sm:inline">About</span>
          </.link>
          <.link
            href={~p"/gallery"}
            class={[
              "inline-flex items-center gap-1 rounded-full px-2 py-1 font-semibold text-white transition",
              if(active_path == "/gallery",
                do: "bg-white/24 text-white shadow-sm",
                else:
                  "hover:bg-white/22 hover:text-white hover:ring-1 hover:ring-white/35 hover:shadow-[0_6px_14px_rgba(24,16,88,0.24)]"
              )
            ]}
          >
            <.icon name="hero-photo" class="h-3.5 w-3.5" />
            <span class="hidden sm:inline">Gallery</span>
          </.link>
          <.link
            href={~p"/"}
            class="inline-flex items-center gap-1 rounded-full bg-white/18 px-2.5 py-1 font-semibold text-white ring-1 ring-white/24 transition hover:bg-white/32 hover:ring-white/40 hover:shadow-[0_6px_14px_rgba(24,16,88,0.24)]"
          >
            <span>+ New Grid</span>
          </.link>
          <%= if @current_user do %>
            <.link
              href={~p"/activity"}
              class={[
                "inline-flex items-center gap-1 rounded-full px-2 py-1 font-semibold text-white transition",
                if(active_path == "/activity",
                  do: "bg-white/24 text-white shadow-sm",
                  else:
                    "hover:bg-white/22 hover:text-white hover:ring-1 hover:ring-white/35 hover:shadow-[0_6px_14px_rgba(24,16,88,0.24)]"
                )
              ]}
            >
              <.icon name="hero-bell" class="h-3.5 w-3.5" />
              <span class="hidden sm:inline">Activity</span>
            </.link>
            <.link
              href={~p"/u/#{@current_user.username}"}
              class={[
                "inline-flex items-center gap-1 rounded-full px-2 py-1 font-semibold text-white transition",
                if(active_path == "/u/#{@current_user.username}",
                  do: "bg-white/24 text-white shadow-sm",
                  else:
                    "hover:bg-white/22 hover:text-white hover:ring-1 hover:ring-white/35 hover:shadow-[0_6px_14px_rgba(24,16,88,0.24)]"
                )
              ]}
            >
              <.icon name="hero-user-circle" class="h-3.5 w-3.5" />
              <span class="hidden sm:inline">My Profile</span>
            </.link>
            <%= if @current_user.is_admin do %>
              <.link
                href={~p"/admin/curated"}
                class={[
                  "inline-flex items-center gap-1 rounded-full px-2 py-1 font-semibold text-white transition",
                  if(active_path == "/admin/curated",
                    do: "bg-white/24 text-white shadow-sm",
                    else:
                      "hover:bg-white/22 hover:text-white hover:ring-1 hover:ring-white/35 hover:shadow-[0_6px_14px_rgba(24,16,88,0.24)]"
                  )
                ]}
              >
                <.icon name="hero-star" class="h-3.5 w-3.5" />
                <span class="hidden sm:inline">Curate</span>
              </.link>
            <% end %>
          <% else %>
            <.link
              href={~p"/users/register"}
              class="inline-flex items-center gap-1 rounded-full bg-white/18 px-2.5 py-1 font-semibold text-white ring-1 ring-white/24 transition hover:bg-white/32 hover:ring-white/40 hover:shadow-[0_6px_14px_rgba(24,16,88,0.24)]"
            >
              Register
            </.link>
            <.link
              href={~p"/users/log_in"}
              class="inline-flex items-center gap-1 rounded-full px-2 py-1 font-semibold text-white transition hover:bg-white/22 hover:text-white hover:ring-1 hover:ring-white/35 hover:shadow-[0_6px_14px_rgba(24,16,88,0.24)]"
            >
              Log in
            </.link>
          <% end %>
        </div>
      </nav>
    </header>

    <main>
      {@inner_content}
    </main>
  </body>
</html>
